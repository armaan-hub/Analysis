# ============================================
# Accounting & Legal AI Chatbot – Environment Template
# ============================================
# Copy this file to .env and fill in your real API keys
# NEVER commit .env to version control

# Active LLM Provider: nvidia | openai | claude | mistral | ollama
LLM_PROVIDER=nvidia

# NVIDIA NIM API
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_MODEL=mistralai/mistral-large-3-675b-instruct-2512
# Fast-mode model (smaller, faster; used when mode=fast)
NVIDIA_FAST_MODEL=mistralai/mistral-small-4-119b-2603
# Fast-mode reasoning effort: none | low | medium | high (default: medium)
NVIDIA_FAST_REASONING_EFFORT=medium
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Mistral
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embedding model (used for RAG)
EMBEDDING_PROVIDER=nvidia
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# Database
DATABASE_URL=sqlite:///./data/chatbot.db

# File storage
UPLOAD_DIR=./uploads
VECTOR_STORE_DIR=./vector_store

# Server
HOST=0.0.0.0
PORT=8000

# Monitoring schedule
MONITOR_INTERVAL_HOURS=6

# PDF OCR fallback (for scanned/image-only PDFs)
PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGES=ara+eng
PDF_OCR_DPI=300
PDF_OCR_MIN_CHARS=20
# Optional: custom tessdata dir (e.g., backend/tessdata with extra traineddata files)
PDF_OCR_TESSDATA_DIR=
# Optional: explicit path to tesseract executable if not on PATH
PDF_OCR_TESSERACT_CMD=
