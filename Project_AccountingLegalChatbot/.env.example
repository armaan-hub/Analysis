# ============================================
# Accounting & Legal AI Chatbot – Environment Template
# ============================================
# Copy this file to .env and fill in your real API keys
# NEVER commit .env to version control

# Active LLM Provider: nvidia | openai | claude | mistral | ollama
LLM_PROVIDER=nvidia

# NVIDIA NIM API
NVIDIA_API_KEY=your-nvidia-api-key-here
NVIDIA_MODEL=mistralai/mistral-large-3-675b-instruct-2512
# Fast-mode model (smaller, faster; used when mode=fast)
NVIDIA_FAST_MODEL=mistralai/mistral-small-4-119b-2603
# Separate API key for fast mode (optional — falls back to NVIDIA_API_KEY if blank)
NVIDIA_FAST_API_KEY=
# Fast-mode reasoning effort: none | high (NVIDIA NIM Mistral only supports these two)
NVIDIA_FAST_REASONING_EFFORT=high
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Mistral
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-large-latest

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq (free tier, OpenAI-compatible)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
# Groq fast model (smaller, lower-latency)
GROQ_FAST_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Brave Search (used for web-search augmentation)
BRAVE_SEARCH_API_KEY=your-brave-search-api-key-here

# Embedding model (used for RAG)
EMBEDDING_PROVIDER=nvidia
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
# OpenAI embedding model (used when EMBEDDING_PROVIDER=openai)
OPENAI_EMBED_MODEL=text-embedding-3-small

# Database
DATABASE_URL=sqlite:///./data/chatbot.db

# File storage
UPLOAD_DIR=./uploads
VECTOR_STORE_DIR=./vector_store
GRAPH_STORE_DIR=./graph_store

# Server
HOST=0.0.0.0
PORT=8000

# Monitoring schedule
MONITOR_INTERVAL_HOURS=6

# PDF OCR fallback (for scanned/image-only PDFs)
PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGES=ara+eng
PDF_OCR_DPI=300
PDF_OCR_MIN_CHARS=20
# Optional: custom tessdata dir (e.g., backend/tessdata with extra traineddata files)
PDF_OCR_TESSDATA_DIR=
# Optional: explicit path to tesseract executable if not on PATH
PDF_OCR_TESSERACT_CMD=

# RAG / retrieval tuning
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
# Number of top chunks to retrieve (analyst / deep_research modes)
TOP_K_RESULTS=8
# Max output tokens for deep/analyst mode
MAX_TOKENS=15649
# Number of top chunks for fast mode (higher retrieval budget)
FAST_TOP_K=15
# Max output tokens for fast mode
FAST_MAX_TOKENS=12385
# Sampling temperature — low for precise legal/accounting answers
TEMPERATURE=0.10
FAST_TEMPERATURE=0.20
DEEP_TEMPERATURE=1.00
# Drop RAG chunks below this cosine-similarity threshold (0 < value < 1)
RAG_MIN_SCORE=0.30
